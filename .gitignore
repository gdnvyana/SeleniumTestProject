cat > .gitignore << 'EOF'
# Compiled files
*.class
target/
build/

# IDE files
.idea/
*.iml
*.iws
*.ipr
.settings/
.project
.classpath
.vscode/

# Logs
*.log
logs/

# Test reports
surefire-reports/
test-output/
build/reports/

# OS files
.DS_Store
Thumbs.db

# Local configuration (важный!)
# Не добавляйте файлы с паролями!
src/test/resources/config/config.properties
src/main/resources/config/config.properties

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# Maven
.mvn/
mvnw
mvnw.cmd

# Selenide downloads
build/downloads/
EOF